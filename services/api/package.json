{
  "name": "@sessionvault/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SessionVault backend API (REST + realtime + static SPA host)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx/esm src/server.ts",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.620.0",
    "@aws-sdk/s3-request-presigner": "^3.620.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.7",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
