# --- SessionVault environment (copy to .env) -------------------------------
#
# BARE MINIMUM for a secure public production deploy — set these 8, leave the
# rest at their defaults:
#   SV_DOMAIN                     your domain (drives automatic Let's Encrypt HTTPS)
#   PUBLIC_BASE_URL              https://<your-domain>
#   POSTGRES_PASSWORD           change from default
#   S3_SECRET_ACCESS_KEY        change from default
#   AUTH_DEFAULT_ADMIN_PASSWORD change from default
# (If you change POSTGRES_PASSWORD, either leave DATABASE_URL unset so it
#  interpolates, or update DATABASE_URL to match.)
# Generate secrets with:  openssl rand -base64 24

# =============================================================================
# HTTPS / public hosting (Caddy reverse proxy)
# =============================================================================
# Set SV_DOMAIN to your public domain to get automatic Let's Encrypt HTTPS.
# Requires: a DNS A/AAAA record pointing at this host, and ports 80 + 443 open.
# Leave as "localhost" for a locally-trusted self-signed cert.
SV_DOMAIN=localhost
# Email for Let's Encrypt expiry notices (recommended for real domains).
SV_TLS_EMAIL=

# Public base URL the app advertises (used to build participant links).
# Local:  https://localhost
# Public: https://sessions.example.com
PUBLIC_BASE_URL=https://localhost

# =============================================================================
# Core
# =============================================================================
NODE_ENV=production
PORT=8080

# Database
POSTGRES_PASSWORD=change-me-postgres
DATABASE_URL=postgres://sessionvault:change-me-postgres@postgres:5432/sessionvault

# =============================================================================
# S3-compatible storage
# =============================================================================
# Media is proxied through the API, so only the server needs to reach storage.
# Browsers never talk to storage directly (no public endpoint / CORS needed).
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me-minio
S3_BUCKET=sessionvault
S3_FORCE_PATH_STYLE=true
#
# External S3 / Cloudflare R2 example (remove the minio service from compose):
#   S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
#   S3_ACCESS_KEY_ID=...
#   S3_SECRET_ACCESS_KEY=...
#   S3_BUCKET=sessionvault
#   S3_FORCE_PATH_STYLE=false

# =============================================================================
# Auth
# =============================================================================
# A default admin is created on first run. CHANGE THE PASSWORD after first login
# (or set a strong one here before first boot).
AUTH_DEFAULT_ADMIN_USERNAME=admin
AUTH_DEFAULT_ADMIN_PASSWORD=change-me-admin
# Send the session cookie only over HTTPS (keep true in production).
AUTH_COOKIE_SECURE=true
AUTH_SESSION_TTL_DAYS=14

# Sessions
SESSION_LINK_TTL_DAYS=7
