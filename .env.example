# --- SessionVault environment (copy to .env) -------------------------------
NODE_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080

# Database (host port 5433 to avoid local 5432 conflicts)
DATABASE_URL=postgres://sessionvault:sessionvault@postgres:5432/sessionvault

# S3-compatible storage (MinIO by default)
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=sessionvault
S3_FORCE_PATH_STYLE=true

# Sessions
SESSION_LINK_TTL_DAYS=7

# Dev auth stub
AUTH_DEV_MODE=true
AUTH_DEV_USER_EMAIL=admin@sessionvault.local
AUTH_DEV_ORG_NAME=Demo Org

# Where the API finds the built SPA (set in container)
WEB_DIST=/app/web
