# SessionVault reverse proxy with automatic HTTPS.
#
# Set SV_DOMAIN in your .env:
#   - A real domain (e.g. sessions.example.com) -> Caddy obtains a Let's Encrypt
#     certificate automatically over HTTP-01. Requires ports 80 + 443 reachable
#     from the internet and a DNS A/AAAA record pointing at this host.
#   - "localhost" (default) -> Caddy serves a locally-trusted self-signed cert.
#
# SV_TLS_EMAIL is used for Let's Encrypt expiry notices (recommended for prod).
# To enable it, uncomment the global block below and set SV_TLS_EMAIL in .env:
#   { email {$SV_TLS_EMAIL} }

# Listen address/port. Default :443 (standard HTTPS). To serve on a custom
# HTTPS port set SV_HTTPS_SITE, e.g. "sessions.example.com:8443".
#
# Certificate challenge notes:
#   - HTTP-01 (default) needs port 80 reachable from the internet.
#   - On a custom port with no port 80, switch to TLS-ALPN-01 or DNS-01 by
#     uncommenting a global block:
#       { acme_dns cloudflare {$CF_API_TOKEN} }      # DNS-01 (no inbound ports)
#     or disable HTTP-01:
#       { servers { protocols h1 h2 } }  +  tls { } using on-demand/alpn
{$SV_HTTPS_SITE:{$SV_DOMAIN:localhost}} {
	encode gzip zstd

	# All traffic (UI, API, and media uploads/playback) goes to the SessionVault
	# API. Media is proxied by the API to/from object storage, so the browser
	# never talks to storage directly and no /s3 route is needed.
	reverse_proxy api:8080 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}
}
